---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "个人简历" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans+SC:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body
    class="bg-white text-gray-900 antialiased dark:bg-[#0a0a0f] dark:text-gray-100"
  >
    <div class="fixed inset-0 -z-10 overflow-hidden">
      <div class="absolute -top-[40%] -right-[20%] h-[600px] w-[600px] rounded-full bg-primary-200/30 blur-[120px] dark:bg-primary-900/20"></div>
      <div class="absolute -bottom-[20%] -left-[20%] h-[500px] w-[500px] rounded-full bg-indigo-200/20 blur-[120px] dark:bg-indigo-900/10"></div>
    </div>
    <slot />
  </body>
</html>

<script is:inline>
  (function () {
    const saved = localStorage.getItem("theme");
    if (saved === "dark" || (!saved && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
      document.documentElement.classList.add("dark");
    }
  })();
</script>
