---
import Layout from "../layouts/Layout.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import Header from "../components/Header.astro";
import About from "../components/About.astro";
import Experience from "../components/Experience.astro";
import Projects from "../components/Projects.astro";
import Skills from "../components/Skills.astro";
import Education from "../components/Education.astro";
import { resume } from "../data/resume";
---

<Layout title={`${resume.name} - ${resume.title}`} description={`${resume.name}的个人简历 - ${resume.title}`}>
  <ThemeToggle />
  <main class="min-h-screen">
    <Header />

    <div class="mx-auto max-w-3xl px-6 sm:px-12">
      <div class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent dark:via-gray-800"></div>
    </div>

    <About />

    <div class="mx-auto max-w-3xl px-6 sm:px-12">
      <div class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent dark:via-gray-800"></div>
    </div>

    <Experience />

    <div class="mx-auto max-w-3xl px-6 sm:px-12">
      <div class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent dark:via-gray-800"></div>
    </div>

    <Projects />

    <div class="mx-auto max-w-3xl px-6 sm:px-12">
      <div class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent dark:via-gray-800"></div>
    </div>

    <Skills />

    <div class="mx-auto max-w-3xl px-6 sm:px-12">
      <div class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent dark:via-gray-800"></div>
    </div>

    <Education />

    <footer class="px-6 py-16 text-center text-sm text-gray-400 dark:text-gray-600">
      <p class="tracking-wide">
        Built with
        <a href="https://astro.build" target="_blank" rel="noopener" class="text-gray-500 transition-colors hover:text-primary-500 dark:text-gray-500">Astro</a>
      </p>
    </footer>
  </main>
</Layout>
