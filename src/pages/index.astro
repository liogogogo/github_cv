---
import Layout from "../layouts/Layout.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import Header from "../components/Header.astro";
import About from "../components/About.astro";
import Experience from "../components/Experience.astro";
import Projects from "../components/Projects.astro";
import Skills from "../components/Skills.astro";
import Education from "../components/Education.astro";
import Honors from "../components/Honors.astro";
import { resume } from "../data/resume";
---

<Layout title={`${resume.name} - ${resume.title}`} description={`${resume.name}的个人简历 - ${resume.title}`}>
  <ThemeToggle />
  <main class="mx-auto min-h-screen max-w-2xl px-6 sm:px-8">
    <Header />
    <hr class="border-gray-100 dark:border-gray-800/50" />
    <About />
    <hr class="border-gray-100 dark:border-gray-800/50" />
    <Experience />
    <hr class="border-gray-100 dark:border-gray-800/50" />
    <Projects />
    <hr class="border-gray-100 dark:border-gray-800/50" />
    <Skills />
    <hr class="border-gray-100 dark:border-gray-800/50" />
    <Education />
    <hr class="border-gray-100 dark:border-gray-800/50" />
    <Honors />

    <footer class="py-12 text-center text-xs text-gray-300 dark:text-gray-700">
      Built with Astro
    </footer>
  </main>
</Layout>
