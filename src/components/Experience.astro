---
import { resume } from "../data/resume";

const { experience } = resume;
---

<section class="px-6 py-10 sm:px-0">
  <div class="mx-auto max-w-[640px]">
    <h2 class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-400 dark:text-gray-500">
      工作经历
    </h2>

    <div class="mt-6 space-y-10">
      {experience.map((exp) => (
        <div>
          <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
            <h3 class="text-[15px] font-semibold text-gray-900 dark:text-white">
              {exp.title}<span class="font-normal text-gray-400 dark:text-gray-500"> · {exp.company}</span>
            </h3>
            <span class="text-xs tabular-nums text-gray-400 dark:text-gray-500">
              {exp.startDate} – {exp.endDate}
            </span>
          </div>
          <ul class="mt-3 space-y-2">
            {exp.description.map((item) => (
              <li class="relative pl-4 text-[13px] leading-relaxed text-gray-600 before:absolute before:left-0 before:top-[0.55em] before:h-1 before:w-1 before:rounded-full before:bg-gray-300 dark:text-gray-400 dark:before:bg-gray-600">
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
