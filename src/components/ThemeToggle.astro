---

---

<button
  id="theme-toggle"
  class="no-print glass fixed top-5 right-5 z-50 flex h-9 w-9 items-center justify-center rounded-full border border-gray-200 bg-white/80 text-gray-500 shadow-sm transition-all hover:scale-110 hover:shadow-md dark:border-gray-700/50 dark:bg-gray-800/80 dark:text-gray-400"
  aria-label="切换深色模式"
  type="button"
>
  <svg
    class="hidden h-4 w-4 dark:block"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
    ></path>
  </svg>
  <svg
    class="block h-4 w-4 dark:hidden"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
    ></path>
  </svg>
</button>

<script is:inline>
  document.getElementById("theme-toggle").addEventListener("click", function () {
    const html = document.documentElement;
    const isDark = html.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  });
</script>
