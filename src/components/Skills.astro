---
import { resume } from "../data/resume";

const { skills } = resume;
---

<section class="px-6 py-10 sm:px-0">
  <div class="mx-auto max-w-[640px]">
    <h2 class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-400 dark:text-gray-500">
      技能
    </h2>

    <div class="mt-6 space-y-4">
      {skills.map((group) => (
        <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
          <span class="w-20 shrink-0 text-[13px] font-medium text-gray-900 dark:text-gray-200">
            {group.category}
          </span>
          <span class="text-[13px] text-gray-500 dark:text-gray-400">
            {group.items.join(" · ")}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
