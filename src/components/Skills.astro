---
import { resume } from "../data/resume";

const { skills } = resume;

const colorMap: Record<string, string> = {
  "编程语言": "bg-blue-50 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300",
  "框架与工具": "bg-green-50 text-green-700 dark:bg-green-900/30 dark:text-green-300",
  "数据存储": "bg-orange-50 text-orange-700 dark:bg-orange-900/30 dark:text-orange-300",
  "AI / ML": "bg-purple-50 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300",
  "DevOps": "bg-cyan-50 text-cyan-700 dark:bg-cyan-900/30 dark:text-cyan-300",
};

function getColor(category: string): string {
  return colorMap[category] ?? "bg-gray-50 text-gray-700 dark:bg-gray-800 dark:text-gray-300";
}
---

<section class="px-6 py-12 sm:px-12">
  <div class="mx-auto max-w-3xl">
    <h2 class="flex items-center gap-3 text-xl font-bold text-gray-900 dark:text-gray-100">
      <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary-100 text-primary-600 dark:bg-primary-900/50 dark:text-primary-400">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
        </svg>
      </span>
      技能
    </h2>

    <div class="mt-6 space-y-4">
      {skills.map((group) => (
        <div>
          <h3 class="mb-2 text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
            {group.category}
          </h3>
          <div class="flex flex-wrap gap-2">
            {group.items.map((item) => (
              <span class={`rounded-lg px-3 py-1.5 text-sm font-medium ${getColor(group.category)}`}>
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
