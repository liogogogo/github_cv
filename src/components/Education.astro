---
import { resume } from "../data/resume";

const { education } = resume;
---

<section class="px-6 py-16 sm:px-12">
  <div class="mx-auto max-w-3xl">
    <h2 class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-400 dark:text-gray-500">
      教育背景
    </h2>

    <div class="mt-8 space-y-8">
      {education.map((edu) => (
        <div class="grid gap-4 sm:grid-cols-[180px_1fr]">
          <div class="flex flex-col text-sm text-gray-400 dark:text-gray-500 sm:text-right">
            <span>{edu.startDate} –</span>
            <span>{edu.endDate}</span>
          </div>
          <div>
            <h3 class="font-semibold text-gray-900 dark:text-white">{edu.school}</h3>
            <p class="mt-0.5 text-sm text-gray-500 dark:text-gray-400">
              {edu.degree} · {edu.major}
            </p>
            {edu.highlights && edu.highlights.length > 0 && (
              <ul class="mt-3 space-y-1">
                {edu.highlights.map((item) => (
                  <li class="relative pl-5 text-sm text-gray-600 before:absolute before:left-0 before:top-[0.55em] before:h-1.5 before:w-1.5 before:rounded-full before:bg-primary-400 dark:text-gray-400 dark:before:bg-primary-500">
                    {item}
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
