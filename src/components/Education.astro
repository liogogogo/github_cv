---
import { resume } from "../data/resume";

const { education } = resume;
---

<section class="px-6 py-10 sm:px-0">
  <div class="mx-auto max-w-[640px]">
    <h2 class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-400 dark:text-gray-500">
      教育背景
    </h2>

    <div class="mt-6 space-y-6">
      {education.map((edu) => (
        <div>
          <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
            <h3 class="text-[15px] font-semibold text-gray-900 dark:text-white">
              {edu.school}<span class="font-normal text-gray-400 dark:text-gray-500"> · {edu.degree} · {edu.major}</span>
            </h3>
            <span class="text-xs tabular-nums text-gray-400 dark:text-gray-500">
              {edu.startDate} – {edu.endDate}
            </span>
          </div>
          {edu.highlights && edu.highlights.length > 0 && (
            <ul class="mt-2 space-y-1">
              {edu.highlights.map((item) => (
                <li class="relative pl-4 text-[13px] text-gray-500 before:absolute before:left-0 before:top-[0.55em] before:h-1 before:w-1 before:rounded-full before:bg-primary-400 dark:text-gray-400">
                  {item}
                </li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
